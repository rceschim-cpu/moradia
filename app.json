{
  "expo": {
    "name": "Projeto Moradia",
    "slug": "moradia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A7B72"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.projetomoradia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A7B72"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.projetomoradia.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Projeto Moradia",
      "shortName": "Moradia",
      "description": "App de doação e engajamento do Projeto Moradia"
    },
    "experiments": {
      "baseUrl": "/moradia"
    }
  }
}
